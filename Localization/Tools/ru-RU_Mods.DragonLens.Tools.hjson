BuffDespawner: {
	DisplayName: Очистить баффы
	Description: Снимает с вас все баффы и дебаффы.
}

DustDespawner: {
	DisplayName: Очистить частицы
	Description: Удаляет все частицы в мире.
}

GoreDespawner: {
	DisplayName: Очистить останки
	Description: Удаляет все останки, которые оставляют существа после смерти.
}

ItemDespawner: {
	DisplayName: Очистить предметы
	Description: Удаляет все предметы, лежащие на земле.
}

NPCDespawner: {
	DisplayName: Очистить существ
	Description:
		'''
		Удаляет всех враждебных существ в мире. Нажмите ПКМ, чтобы избавиться от существ более «привычным» образом.
		Удерживайте Shift, чтобы также удалить всех дружественных существ.
		'''
	RightClickName: Убить всех существ
}

ProjectileDespawner: {
	DisplayName: Очистить снаряды
	Description: Удаляет все снаряды в мире.
}

ShaderCompiler: {
	DisplayName: Перезагрузка шейдеров
	Description: Рекомпиляция и перезагрудка всех шейдеров [ИНСТРУМЕНТ ВСЁ ЕЩЁ В РАЗРАБОТКЕ]
	Busy: Компилятор шейдеров занят! Пожалуйста, подождите...
	Triggered: Начата рекомпиляция шейдеров...
	Completed: Рекомпиляция шейдеров завершена за {0} мс.
	Recompiled: Шейдер {0} рекомпилирован!
}

AccessoryTray: {
	DisplayName: Облачное хранилище аксессуаров
	Description: Практически бесконечная виртуальная коллекция дополнительных слотов под аксессуары!
	MpDisabled: Облачное хранилище аксессуаров отключено в мультиплеере.
	PlaceAccHere: Поместите ваш аксессуар сюда!
}

ItemEditor: {
	DisplayName: Редактор предметов
	Description: Позволяет изменять характеристики и другие свойства предметов.
	AutogenMsg: Возможность редактирования этого параметра была автоматически сгенерирована методом отражения. Его изменение может привести к неизвестным последствиям.
	VanillaFields: Ванильные параметры
	Modded: Модовые параметры
	Prefixes: Модификаторы
	PlaceItemHere:
		'''
		Поместите ваш
		предмет сюда!
		'''
	SetDefaults: Сброс изменений

	Filters: {
		FromMod: Из мода {0}
		FromVanilla: Из ванильной игры
	}

	Editors: {
		Damage: {
			Name: Урон
			Description: Сколько урона будет наносить этот предмет и выпускаемые им снаряды.
		}

		CritChance: {
			Name: Крит. шанс
			Description: К выбранному значению добавляется 4% базового шанса критического удара.
		}

		Knockback: {
			Name: Отбрасывание
			Description: Насколько далеко будет отброшен враг при получении урона от этого предмета.
		}

		UseStyle: {
			Name: Тип использования
			Description:
				'''
				0: None (нельзя использовать)
				1: Swing (взмах)
				3: Thrust (выпад)
				4: HoldUp (удержание над головой)
				5: Shoot (стрельба)
				6: DrinkLong (длинная анимация питья)
				7: DrinkOld (старая анимация питья)
				8: GolfPlay (клюшка для гольфа)
				9: DrinkLiquid (новая анимация питья)
				10: HiddenAnimation (без анимации использования)
				11: MowTheLawn (газонокосилка)
				12: Guitar (гитара)
				13: Rapier (кинжалы)
				14: RaiseLamp (фонарь)
				'''
		}

		UseTime: {
			Name: Время использования
			Description: Сколько тиков пройдёт перед тем, как этот предмет используется повторно вне зависимости от периодичности нажатий клавиш.
		}

		UseAnimation: {
			Name: Длительность анимации
			Description: Сколько тиков пройдёт, перед тем, как вы сможете отменить использование этого предмета или использовать его снова.
		}

		AutoReuse: {
			Name: Автоатака
			Description: Будет ли этот предмет автоматически использоваться, если удерживать ЛКМ.
		}

		ReuseDelay: {
			Name: Пауза между использованиями
			Description: Сколько тиков пройдёт после окончания использования этого предмета перед тем, как его можно будет использовать снова.
		}

		PickaxePower: {
			Name: Мощность кирки
			Description: Насколько хорошо этот предмет будет ломать блоки.
		}

		AxePower: {
			Name: Мощность топора
			Description: Насколько хорошо этот предмет будет рубить деревья. Итоговое значение будет умножаться на 5.
		}

		HammerPower: {
			Name: Мощность молота
			Description: Насколько хорошо этот предмет будет ломать стены.
		}

		Rarity: {
			Name: Редкость
			Description: Цвет, которым будет отображаться название этого предмета.
		}

		Value: {
			Name: Стоимость
			Description: Базовая стоимость продажи этого предмета в медных монетах.
		}

		ProjectileType: {
			Name: Тип снаряда
			Description:
				'''
				Какой снаряд будет выпускать этот предмет при использовании.
				Используйте браузер снарядов, чтобы найти необходимый вам тип снаряда.
				'''
		}

		ShootSpeed: {
			Name: Скорость снарядов
			Description: Насколько быстро будут лететь снаряды, выпускаемые этим предметом.
		}

		Color: {
			Name: Цвет
			Description: Цветовой фильтр для спрайта этого предмета.
		}
	}
}

PlayerEditor: {
	DisplayName: Редактор игрока
	Description: Позволяет изменять характеристики и другие свойства вашего персонажа.
	AutogenMsg: Возможность редактирования этого параметра была автоматически сгенерирована методом отражения. Его изменение может привести к неизвестным последствиям.
	VanillaFields: Ванильные параметры
	ModPlayers: Модовые параметры

	Editors: {
		MaxLife: {
			Name: Макс. здоровье
			Description: Максимальное здоровье игрока, достигаемое ванильными способами. Изменение этого параметра на значения меньше 20 или больше 500 может привести к странным последствиям.
		}

		MaxMana: {
			Name: Макс. мана
			Description: Максимальная мана игрока, достигаемая ванильными способами. Изменение этого параметра на значения меньше 20 или больше 200 может привести к странным последствиям.
		}

		ExtraLife: {
			Name: Доп. здоровье
			Description: Позволяет вам прибавить любое количество здоровья к базовому значению.
		}

		ExtraMana: {
			Name: Доп. мана
			Description: Позволяет вам прибавить любое количество маны к базовому значению.
		}

		ExtraDefense: {
			Name: Доп. защита
			Description: Позволяет вам прибавить любое количество защиты к базовому значению.
		}

		ExtraEndurance: {
			Name: Доп. сопротивление урону
			Description: Позволяет вам прибавить любое количество сопротивления урону к базовому значению.
		}

		ExtraMinionSlots: {
			Name: Доп. слоты миньонов
			Description: Позволяет вам прибавить любое количество слотов миньонов к базовому значению.
		}

		ExtraSpeed: {
			Name: Доп. скорость передвижения
			Description: Позволяет вам прибавить любое количество скорости передвижения к базовому значению.
		}

		InfWingTime: {
			Name: Бесконечный полёт
			Description: Даёт всем крыльям неограниченное время полёта.
		}
	}
}

Difficulty: {
	DisplayName: Сменить режим сложности
	Description:
		'''
		Позволяет переключаться между тремя режимами сложности игры. 
		Нажмите ПКМ, чтобы переключить режим путешествия.
		'''
	RightClickName: Переключить режим путешествия
	GameInNormalMode: Установлен классический режим.
	GameInExpertMode: Установлен режим эксперта.
	GameInMasterMode: Установлен режим мастера.
	JourneyToggleDisabled: Переключение режима путешествия отключено в мультиплеере.
	JourneyEnabled: Режим путешествия включён.
	JourneyDisabled: Режим путешествия отключён.
}

FastForward: {
	DisplayName: Ускорение игры
	Description:
		'''
		Нажмите ЛКМ, чтобы ускорить всю игру вплоть до 4 раз.
		Нажмите ПКМ, чтобы переключаться между ускорениями в обратном порядке, от большего к меньшему.
		'''
	RightClickName: Замедление игры
	MultiplayerDisabled: Ускорение отключено в мультиплеере.
}

Godmode: {
	DisplayName: Режим бога
	Description:
		'''
		Нажмите ЛКМ, чтобы отключить смерти, получение урона и расход маны.
		Нажмите ПКМ, чтобы отключить смерти, но по прежнему получать урон и расходовать ману.
		'''
	RightClickName: Режим бессмертия
	PreventedDeath: Режим бессмертия предотвратил вашу смерть от следующей причины: {0}
}

InfiniteReach: {
	DisplayName: Безграничное строительство
	Description: Включает неограниченную досягаемость и мгновенную установку блоков и стен.
}

Magnet: {
	DisplayName: Магнит предметов
	Description:
		'''
		Нажмите ЛКМ, чтобы притягивать к себе все предметы, лежащие на земле.
		Нажмите ПКМ, чтобы уничтожать все предметы, лежащие на земле.
		'''
	RightClickName: Уничтожитель предметов
}

NoClip: {
	DisplayName: Ноуклип
	Description: Позволяет свободно передвигаться, игнорируя коллизию блоков.
}

Paint: {
	DisplayName: Инструменты копирования
	Description: Позволяет копировать и вставлять части мира.
	CreateStructure: Копировать
	FirstPointSet: Первая точка установлена!
	StructureSaved: Выделенная область сохранена в меню этого инструмента!
	TempStructure: Временный объект «{0}»

	Advertise: {
		Title:
			'''
			Скачать
			прямо
			сейчас!
			'''
		Content:
			'''
			Ознакомитесь с модом
			Structure Helper, в котором гораздо больше полезных функций!
			С ним вы сможете:
			> Экспортировать выде-
			ленные вами структуры и процедурное генерирова-
			ть их в своих модах
			> Использовать нуль-
			блоки, позволяющие вашим структурам быть не толь-
			ко прямоугольной формы!
			> Устанавливать сундуки со своим или случайным содержимым!
			'''
		Downloaded: StructureHelper скачивается. Вернитесь в главное меню, а затем перейдите в список модов, чтобы его включить!
	}
}

SpawnTool: {
	DisplayName: Изменить частоту появления существ
	Description: Позволяет установить частоту появления существ или полностью отключать их появление.
	EnemySpawnRate: Частота появления
	SpawnRate: Множитель частоты появления: {0}
}

Time: {
	DisplayName: Изменить время
	Description: Позволяет управлять циклом дня и ночи.
	UITitle: Установить время
	Day: День
	Night: Ночь
	CurrentTime: ({0}: кадр {1} из {2})
	Resume: Возобновить время
	Freeze: Остановить время
	FreezeTooltip: Позволяет останавливать течение времени. Это в том числе сохранит текущий момент времени между мирами и перезапусками игры!
}

Weather: {
	DisplayName: Изменить погоду
	Description: Позволяет изменять погоду
	UITitle: Установить погодные условия
	Combinations:
		'''
		Полезные сочетания:
		Сильный дождь + ветер > 20 миль/ч = буря
		Естественный дождь + снежный биом = метель
		'''
	RainIntensity: Интенсивность дождя
	RainLow: слабая
	RainMedium: средняя
	RainHigh: сильная
	WindStrength: Сила ветра
	WindSixtyWest:
		'''
		60 миль/ч
		с востока
		'''
	WindSixtyEast:
		'''
		60 миль/ч
		с запада
		'''
	WindTwentyWest:
		'''
		20 миль/ч
		c востока
		'''
	WindTwentyEast:
		'''
		20 миль/ч
		с запада
		'''

	RainButton: {
		Name: Дождь
		Tooltip:
			'''
			Включить/Выключить естественный дождь. 
			Вы по прежнему будете наблюдать остатки дождя во время его угасания или естественных событий, связанных с дождём.
			'''
	}

	SandstormButton: {
		Name: Песчаная буря
		Tooltip:
			'''
			Включить/Выключить песчаную бурю.
			Её можно наблюдать исключительно в пустыне.
			'''
	}

	FreezeWeatherButton: {
		Freeze: Остановить погоду
		Resume: Возобновить погоду
		Tooltip: Позволяет останавливать естественное изменение погоды. Это сохранит текущие погодные условия между мирами и перезапусками игры!
	}
}

HideMap: {
	DisplayName: Забыть всю карту
	Description: Удаляет весь прогресс исследования карты.
}

MapTeleport: {
	DisplayName: Телепортация по карте
	Description:
		'''
		Переключает возможность телепортироваться по карте.
		Нажмите ПКМ по любому месту на карте, чтобы телепортироваться туда.
		'''
	OutsideWorldWarning: Вы не можете телепортироваться за границы мира!
}

RevealMap: {
	DisplayName: Исследовать всю карту
	Description: Открывает всю карту
}

